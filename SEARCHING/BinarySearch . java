public class BinarySearch {

    public static void main(String[] args) {

        int[] arr = {10, 20, 30, 40, 50};
        int key = 30;

        int left = 0;
        int right = arr.length - 1;

        boolean found = false;

        while (left <= right) {

            int mid = (left + right) / 2;

            if (arr[mid] == key) {
                found = true;
                break;
            }

            else if (key < arr[mid]) {
                right = mid - 1;
            }

            else {
                left = mid + 1;
            }
        }

        if (found)
            System.out.println("Element found");
        else
            System.out.println("Element not found");
    }
}
